#!/usr/bin/env bash
set -euo pipefail

# --- Config -----------------------------------------------------------------
MAX_SIZE_MB=100
MAX_SIZE_BYTES=$((MAX_SIZE_MB * 1024 * 1024))

# Extensions that have a size limit (case-insensitive)
SIZE_LIMITED_RE='\.(png|jpg|jpeg|webp)$'

# Extensions that are forbidden outright (case-insensitive)
FORBIDDEN_RE='\.(mp4|avi|mkv|mov|webm)$'
# ---------------------------------------------------------------------------

# Portable file-size helper (Linux vs macOS/BSD)
filesize() {
    if stat --version >/dev/null 2>&1; then
        stat -c%s "$1"          # GNU/Linux
    else
        stat -f%z "$1"          # macOS/BSD
    fi
}

errors=0

# Only look at files that are staged for commit (Added/Copied/Modified),
# NUL-delimited so filenames with spaces/newlines are safe.
while IFS= read -r -d '' file; do
    # Skip anything that was deleted/renamed away
    [ -f "$file" ] || continue

    lower=$(printf '%s' "$file" | tr '[:upper:]' '[:lower:]')

    # 1. Forbidden types
    if printf '%s' "$lower" | grep -Eq "$FORBIDDEN_RE"; then
        echo "FORBIDDEN file type: $file"
        errors=$((errors + 1))
        continue
    fi

    # 2. Size-limited types
    if printf '%s' "$lower" | grep -Eq "$SIZE_LIMITED_RE"; then
        size=$(filesize "$file")
        if [ "$size" -gt "$MAX_SIZE_BYTES" ]; then
            printf 'TOO LARGE (%.1f MB > %d MB): %s\n' \
                "$(echo "$size / 1048576" | bc -l)" "$MAX_SIZE_MB" "$file"
            errors=$((errors + 1))
        fi
    fi
done < <(git diff --cached --name-only --diff-filter=ACM -z)

if [ "$errors" -gt 0 ]; then
    echo ""
    echo "Commit rejected: $errors file(s) violated content rules."
    exit 1
fi

exit 0

